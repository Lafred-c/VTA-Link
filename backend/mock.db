-- ══════════════════════════════════════════════════════════════
-- RLS POLICIES
-- ══════════════════════════════════════════════════════════════


-- ── attendance_logs ──────────────────────────────────────────
CREATE POLICY "Admin full access attendance_logs"
  ON public.attendance_logs FOR ALL TO public USING (is_admin());
CREATE POLICY "Staff read attendance_logs"
  ON public.attendance_logs FOR SELECT TO public USING (is_staff());


-- ── attendance_punch_logs ────────────────────────────────────
CREATE POLICY "Admin full access punch_logs"
  ON public.attendance_punch_logs FOR ALL TO public USING (is_admin());
CREATE POLICY "Staff read punch_logs"
  ON public.attendance_punch_logs FOR SELECT TO public USING (is_staff());


-- ── attendance_summary_imports ───────────────────────────────
CREATE POLICY "Admin full access attendance_summary_imports"
  ON public.attendance_summary_imports FOR ALL TO public USING (is_admin());
CREATE POLICY "Staff read attendance_summary_imports"
  ON public.attendance_summary_imports FOR SELECT TO public USING (is_staff());


-- ── audit_logs ───────────────────────────────────────────────
CREATE POLICY audit_admin_read
  ON public.audit_logs FOR SELECT TO public USING (is_admin());
CREATE POLICY audit_staff_insert
  ON public.audit_logs FOR INSERT TO public WITH CHECK (is_staff());


-- ── cart_items ───────────────────────────────────────────────
-- Customers can only access their own cart
CREATE POLICY cart_select ON public.cart_items FOR SELECT TO public USING (customer_id = auth.uid());
CREATE POLICY cart_insert ON public.cart_items FOR INSERT TO public WITH CHECK (customer_id = auth.uid());
CREATE POLICY cart_update ON public.cart_items FOR UPDATE TO public USING (customer_id = auth.uid());
CREATE POLICY cart_delete ON public.cart_items FOR DELETE TO public USING (customer_id = auth.uid());


-- ── cash_advances ────────────────────────────────────────────
CREATE POLICY "Admin full access cash_advances"
  ON public.cash_advances FOR ALL TO authenticated
  USING (EXISTS (SELECT 1 FROM users WHERE users.id = auth.uid() AND users.role = 'admin'))
  WITH CHECK (EXISTS (SELECT 1 FROM users WHERE users.id = auth.uid() AND users.role = 'admin'));
CREATE POLICY "Cashier insert cash_advances"
  ON public.cash_advances FOR INSERT TO authenticated
  WITH CHECK (EXISTS (SELECT 1 FROM users WHERE users.id = auth.uid() AND users.role = ANY(ARRAY['admin','cashier'])));
CREATE POLICY "Admin update cash_advances"
  ON public.cash_advances FOR UPDATE TO authenticated
  USING (EXISTS (SELECT 1 FROM users WHERE users.id = auth.uid() AND users.role = ANY(ARRAY['admin','cashier'])))
  WITH CHECK (EXISTS (SELECT 1 FROM users WHERE users.id = auth.uid() AND users.role = ANY(ARRAY['admin','cashier'])));
CREATE POLICY "Staff read cash_advances"
  ON public.cash_advances FOR SELECT TO authenticated
  USING (EXISTS (SELECT 1 FROM users WHERE users.id = auth.uid()
    AND users.role = ANY(ARRAY['admin','cashier','designer','production'])));


-- ── chat_messages ────────────────────────────────────────────
-- Users can only see/send their own messages
CREATE POLICY chat_select ON public.chat_messages FOR SELECT TO public
  USING (auth.uid() = sender_id OR auth.uid() = receiver_id);
CREATE POLICY chat_insert ON public.chat_messages FOR INSERT TO public
  WITH CHECK (auth.uid() = sender_id);


-- ── deliveries ───────────────────────────────────────────────
CREATE POLICY "Admin full access deliveries"
  ON public.deliveries FOR ALL TO public USING (is_admin());
CREATE POLICY "Staff can view deliveries"
  ON public.deliveries FOR SELECT TO public USING (is_staff());
CREATE POLICY "Production can request restocks"
  ON public.deliveries FOR INSERT TO public WITH CHECK (get_user_role() = ANY(ARRAY['production','admin']));
CREATE POLICY "Cashier can confirm deliveries"
  ON public.deliveries FOR UPDATE TO public USING (get_user_role() = ANY(ARRAY['cashier','admin']));


-- ── employees ────────────────────────────────────────────────
CREATE POLICY employees_staff_read   ON public.employees FOR SELECT TO public USING (is_staff());
CREATE POLICY employees_admin_insert ON public.employees FOR INSERT TO public WITH CHECK (is_admin());
CREATE POLICY employees_admin_update ON public.employees FOR UPDATE TO public USING (is_admin());
CREATE POLICY employees_admin_delete ON public.employees FOR DELETE TO public USING (is_admin());


-- ── inventory_changes ────────────────────────────────────────
-- NOTE: Has duplicate policies for both {public} and {authenticated} roles (functionally redundant)
CREATE POLICY inv_changes_staff_read   ON public.inventory_changes FOR SELECT TO public USING (is_staff());
CREATE POLICY inv_changes_staff_insert ON public.inventory_changes FOR INSERT TO public
  WITH CHECK (get_user_role() = ANY(ARRAY['admin','production']));
-- Also: "Allow authenticated inserts" (WITH CHECK true) — overly permissive, consider removing


-- ── inventory_items ──────────────────────────────────────────
-- NOTE: "Allow authenticated updates on inventory_items" (USING true, WITH CHECK true) — overly permissive
CREATE POLICY inventory_staff_read   ON public.inventory_items FOR SELECT TO public USING (is_staff());
CREATE POLICY inventory_admin_insert ON public.inventory_items FOR INSERT TO public WITH CHECK (is_admin());
CREATE POLICY inventory_admin_update ON public.inventory_items FOR UPDATE TO public USING (is_admin());
CREATE POLICY inventory_admin_delete ON public.inventory_items FOR DELETE TO public USING (is_admin());


-- ── item_suppliers ───────────────────────────────────────────
-- NOTE: Has duplicate policies for both {public} and {authenticated} roles
CREATE POLICY item_suppliers_staff_read   ON public.item_suppliers FOR SELECT TO public USING (is_staff());
CREATE POLICY item_suppliers_admin_insert ON public.item_suppliers FOR INSERT TO public WITH CHECK (is_admin());
CREATE POLICY item_suppliers_admin_update ON public.item_suppliers FOR UPDATE TO public USING (is_admin());
CREATE POLICY item_suppliers_admin_delete ON public.item_suppliers FOR DELETE TO public USING (is_admin());


-- ── notifications ────────────────────────────────────────────
CREATE POLICY "Users can view their own notifications"
  ON public.notifications FOR SELECT TO public USING (auth.uid() = user_id);
CREATE POLICY "Users can update their own notifications"
  ON public.notifications FOR UPDATE TO public USING (auth.uid() = user_id);
CREATE POLICY "System can insert notifications"
  ON public.notifications FOR INSERT TO public WITH CHECK (true);       -- open insert for trigger-based inserts
CREATE POLICY notifications_admin_all
  ON public.notifications FOR ALL TO public USING (is_admin());


-- ── order_items ──────────────────────────────────────────────
CREATE POLICY oi_select ON public.order_items FOR SELECT TO public
  USING (EXISTS (SELECT 1 FROM orders o WHERE o.id = order_items.order_id
    AND (o.customer_id = auth.uid() OR o.created_by = auth.uid())) OR is_staff());
CREATE POLICY oi_insert ON public.order_items FOR INSERT TO public
  WITH CHECK (EXISTS (SELECT 1 FROM orders o WHERE o.id = order_items.order_id) OR is_staff());
CREATE POLICY oi_update ON public.order_items FOR UPDATE TO public USING (is_staff());
CREATE POLICY oi_delete ON public.order_items FOR DELETE TO public
  USING (is_admin() OR EXISTS (SELECT 1 FROM orders o
    WHERE o.id = order_items.order_id AND o.customer_id = auth.uid() AND o.status = 'in_queue'));


-- ── order_logs ───────────────────────────────────────────────
CREATE POLICY order_logs_staff_read   ON public.order_logs FOR SELECT TO public USING (is_staff());
CREATE POLICY order_logs_admin_manage ON public.order_logs FOR ALL    TO public USING (is_admin());


-- ── orders ───────────────────────────────────────────────────
CREATE POLICY orders_select ON public.orders FOR SELECT TO public
  USING (customer_id = auth.uid() OR created_by = auth.uid() OR is_staff());
CREATE POLICY orders_insert ON public.orders FOR INSERT TO public
  WITH CHECK (customer_id = auth.uid() OR get_user_role() = ANY(ARRAY['admin','cashier']) OR customer_id IS NULL);
CREATE POLICY orders_update_staff ON public.orders FOR UPDATE TO authenticated
  USING (is_staff()) WITH CHECK (is_staff());
CREATE POLICY orders_update_customer_accept_design ON public.orders FOR UPDATE TO authenticated
  USING (customer_id = auth.uid() AND status = 'designing' AND final_design_url IS NOT NULL)
  WITH CHECK (customer_id = auth.uid() AND status = 'payment');
-- NOTE: "Allow authenticated to update order payment status" (USING true, WITH CHECK true) — overly permissive
CREATE POLICY orders_delete ON public.orders FOR DELETE TO authenticated
  USING ((SELECT role FROM users WHERE id = auth.uid()) = 'admin'
    OR (customer_id = auth.uid() AND status = 'in_queue'));


-- ── payments ─────────────────────────────────────────────────
-- NOTE: "Enable insert for authenticated users" (WITH CHECK true) — bypasses cashier-only restriction
-- NOTE: "Enable read access for authenticated users" (USING true) — all authenticated users can read all payments
CREATE POLICY payments_select ON public.payments FOR SELECT TO public
  USING (EXISTS (SELECT 1 FROM orders o WHERE o.id = payments.order_id AND o.customer_id = auth.uid()) OR is_staff());
CREATE POLICY payments_insert ON public.payments FOR INSERT TO public
  WITH CHECK (get_user_role() = ANY(ARRAY['admin','cashier']));
CREATE POLICY payments_update ON public.payments FOR UPDATE TO authenticated
  USING (get_user_role() = ANY(ARRAY['admin','cashier']))
  WITH CHECK (get_user_role() = ANY(ARRAY['admin','cashier']));
CREATE POLICY payments_delete ON public.payments FOR DELETE TO authenticated
  USING ((SELECT role FROM users WHERE id = auth.uid()) = 'admin'
    OR EXISTS (SELECT 1 FROM orders o WHERE o.id = payments.order_id
      AND o.customer_id = auth.uid() AND o.status = 'in_queue'));


-- ── payroll_periods ──────────────────────────────────────────
CREATE POLICY "Admin full access payroll_periods"
  ON public.payroll_periods FOR ALL    TO public USING (is_admin());
CREATE POLICY "Staff read payroll_periods"
  ON public.payroll_periods FOR SELECT TO public USING (is_staff());


-- ── payroll_records ──────────────────────────────────────────
CREATE POLICY "Admin full access payroll_records"
  ON public.payroll_records FOR ALL    TO public USING (is_admin());
CREATE POLICY "Staff read payroll_records"
  ON public.payroll_records FOR SELECT TO public USING (is_staff());


-- ── product_supply_mapping ───────────────────────────────────
-- NOTE: Has duplicate policies for both {public} and {authenticated} roles
CREATE POLICY psm_staff_read   ON public.product_supply_mapping FOR SELECT TO public USING (is_staff());
CREATE POLICY psm_admin_insert ON public.product_supply_mapping FOR INSERT TO public WITH CHECK (is_admin());
CREATE POLICY psm_admin_update ON public.product_supply_mapping FOR UPDATE TO public USING (is_admin());
CREATE POLICY psm_admin_delete ON public.product_supply_mapping FOR DELETE TO public USING (is_admin());


-- ── products ─────────────────────────────────────────────────
-- NOTE: Has duplicate policies for both {public} and {authenticated} roles
CREATE POLICY products_anyone_read_active ON public.products FOR SELECT TO public
  USING (is_active = true OR is_staff());                               -- public can see active products
CREATE POLICY products_admin_insert ON public.products FOR INSERT TO public WITH CHECK (is_admin());
CREATE POLICY products_admin_update ON public.products FOR UPDATE TO public USING (is_admin());
CREATE POLICY products_admin_delete ON public.products FOR DELETE TO public USING (is_admin());


-- ── receipts ─────────────────────────────────────────────────
CREATE POLICY receipts_staff_all ON public.receipts FOR ALL TO public USING (is_staff());
CREATE POLICY receipts_customer_read ON public.receipts FOR SELECT TO public
  USING (EXISTS (SELECT 1 FROM payments p JOIN orders o ON p.order_id = o.id
    WHERE p.id = receipts.payment_id AND o.customer_id = auth.uid()));


-- ── sales_reports ────────────────────────────────────────────
CREATE POLICY sales_reports_admin_all ON public.sales_reports FOR ALL TO public USING (is_admin());


-- ── suppliers ────────────────────────────────────────────────
-- NOTE: Has duplicate policies for both {public} and {authenticated} roles
CREATE POLICY suppliers_staff_read   ON public.suppliers FOR SELECT TO public USING (is_staff());
CREATE POLICY suppliers_admin_insert ON public.suppliers FOR INSERT TO public WITH CHECK (is_admin());
CREATE POLICY suppliers_admin_update ON public.suppliers FOR UPDATE TO public USING (is_admin());
CREATE POLICY suppliers_admin_delete ON public.suppliers FOR DELETE TO public USING (is_admin());


-- ── users ────────────────────────────────────────────────────
CREATE POLICY users_read_own ON public.users FOR SELECT TO public USING (id = auth.uid());
CREATE POLICY users_staff_read_all ON public.users FOR SELECT TO public USING (is_staff());
CREATE POLICY users_select ON public.users FOR SELECT TO public
  USING (id = auth.uid() OR i_am_staff() OR lower(role) = ANY(ARRAY['admin','cashier','designer','production'])
    OR id IN (SELECT sender_id FROM chat_messages WHERE receiver_id = auth.uid())
    OR id IN (SELECT receiver_id FROM chat_messages WHERE sender_id = auth.uid()));
CREATE POLICY users_admin_all ON public.users FOR ALL TO public USING (is_admin());
CREATE POLICY users_admin_insert ON public.users FOR INSERT TO public WITH CHECK (is_admin() OR id = auth.uid());
CREATE POLICY users_update_own ON public.users FOR UPDATE TO public
  USING (id = auth.uid()) WITH CHECK (id = auth.uid());
CREATE POLICY users_admin_update_any ON public.users FOR UPDATE TO public USING (is_admin());
CREATE POLICY users_delete_admin ON public.users FOR DELETE TO public USING (is_admin());




-- ══════════════════════════════════════════════════════════════
-- STORAGE BUCKETS
-- ══════════════════════════════════════════════════════════════


-- Bucket: chat-attachments | public: true | no size limit | any mime type
-- Bucket: order-files      | public: true | no size limit | any mime type
-- Bucket: user-profile     | public: true | no size limit | any mime type


-- Realtime: chat_messages is subscribed to supabase_realtime publication


-- Storage Policies (storage.objects):


-- order-files
--   SELECT  → public read (bucket_id = 'order-files')
--   SELECT  → authenticated read (bucket_id = 'order-files')
--   INSERT  → authenticated upload (bucket_id = 'order-files')
--   INSERT  → owner-scoped upload: foldername[1] = auth.uid()
--   UPDATE  → owner only: foldername[1] = auth.uid()
--   DELETE  → owner only: foldername[1] = auth.uid()


-- chat-attachments
--   INSERT  → owner-scoped: (storage.foldername(name))[1] = auth.uid()::text
--   SELECT  → public read
--   UPDATE  → owner only
--   DELETE  → owner only
-- NOTE: A separate policy "Authenticated users can upload 14tobej_0" has WITH CHECK (true)
--       → Any authenticated user can upload anywhere. Consider removing this policy.


-- user-profile
--   SELECT  → public read (via "Public can view 14tobej_0" policy — suspicious name, likely a leftover)